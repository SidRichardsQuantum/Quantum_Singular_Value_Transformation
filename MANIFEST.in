include CHANGELOG.md
include LICENSE
include MANIFEST.in
include README.md
include RELEASING.md
include ROADMAP.md
include THEORY.md
include USAGE.md
include requirements.txt
include pyproject.toml
include src/qsvt/py.typed

graft src

# The PyPI artifacts are package-focused. Full documentation, notebooks,
# committed result snapshots, and regression tests live in the GitHub
# repository and rendered project documentation instead of the sdist.
prune docs/_build
prune docs
prune notebooks
prune results
prune tests

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude .coverage
global-exclude coverage.xml
global-exclude .ipynb_checkpoints
global-exclude *.nbconvert.ipynb
prune build
prune dist
prune htmlcov
prune .mypy_cache
prune .pytest_cache
prune .hypothesis
prune .ruff_cache
prune .venv
prune env
prune venv
